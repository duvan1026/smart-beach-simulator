[
    {
        "id": "tab-orchestrator",
        "type": "tab",
        "label": "Orchestrator",
        "disabled": false,
        "info": "MQTT -> Combine -> RabbitMQ"
    },
    {
        "id": "cfg-mqtt-broker",
        "type": "mqtt-broker",
        "name": "Mosquitto",
        "broker": "mosquitto",
        "port": "1883",
        "clientid": "nodered-orchestrator",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "4",
        "keepalive": "60",
        "cleansession": true
    },
    {
        "id": "mqtt-in-beach",
        "type": "mqtt in",
        "z": "tab-orchestrator",
        "name": "Beach Sensors (beach/#)",
        "topic": "beach/#",
        "qos": "1",
        "datatype": "json",
        "broker": "cfg-mqtt-broker",
        "x": 150,
        "y": 120,
        "wires": [["func-combine"]]
    },
    {
        "id": "func-combine",
        "type": "function",
        "z": "tab-orchestrator",
        "name": "Combine per Beach",
        "func": "var parts = msg.topic.split('/');\nvar beachId = parts[1];\nvar sensorType = parts[2];\nvar payload = msg.payload;\n\nvar state = context.get(beachId) || {};\nstate[sensorType] = payload;\nstate.lastUpdate = new Date().toISOString();\ncontext.set(beachId, state);\n\nvar sensors = ['wind','pressure','temperature','sealevel','occupancy'];\nvar complete = sensors.every(function(s) { return state[s] !== undefined; });\n\nif (complete) {\n    var combined = {\n        beachId: beachId,\n        timestamp: state.lastUpdate,\n        windSpeed: state.wind.value,\n        pressure: state.pressure.value,\n        temperature: state.temperature.value,\n        seaLevel: state.sealevel.value,\n        occupancy: state.occupancy.value\n    };\n    msg.payload = combined;\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 400,
        "y": 120,
        "wires": [["func-rabbitmq-publish", "debug-combined"]]
    },
    {
        "id": "func-rabbitmq-publish",
        "type": "function",
        "z": "tab-orchestrator",
        "name": "Publish to RabbitMQ",
        "func": "var amqplib = global.get('amqplib');\nif (!amqplib) {\n    node.error('amqplib not available in global context');\n    return null;\n}\n\nvar conn = flow.get('amqpConn');\nvar ch = flow.get('amqpChannel');\n\nif (ch) {\n    try {\n        var exchange = 'beach.events';\n        var routingKey = 'beach.combined';\n        var msgBuffer = Buffer.from(JSON.stringify(msg.payload));\n        ch.publish(exchange, routingKey, msgBuffer, { persistent: true });\n    } catch (e) {\n        node.warn('RabbitMQ publish error, reconnecting: ' + e.message);\n        flow.set('amqpChannel', null);\n        flow.set('amqpConn', null);\n    }\n    return null;\n}\n\namqplib.connect('amqp://beach:monitor@beach-rabbitmq:5672/')\n    .then(function(connection) {\n        flow.set('amqpConn', connection);\n        return connection.createChannel();\n    })\n    .then(function(channel) {\n        var exchange = 'beach.events';\n        return channel.assertExchange(exchange, 'topic', { durable: true })\n            .then(function() {\n                flow.set('amqpChannel', channel);\n                var msgBuffer = Buffer.from(JSON.stringify(msg.payload));\n                channel.publish(exchange, 'beach.combined', msgBuffer, { persistent: true });\n                node.status({ fill: 'green', shape: 'dot', text: 'connected' });\n            });\n    })\n    .catch(function(err) {\n        node.error('RabbitMQ connection failed: ' + err.message);\n        node.status({ fill: 'red', shape: 'ring', text: 'disconnected' });\n    });\n\nreturn null;",
        "outputs": 0,
        "x": 670,
        "y": 80,
        "wires": []
    },
    {
        "id": "debug-combined",
        "type": "debug",
        "z": "tab-orchestrator",
        "name": "Combined Debug",
        "active": false,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "x": 660,
        "y": 120,
        "wires": []
    },

