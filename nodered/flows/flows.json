    {
        "id": "inject-load-patterns",
        "type": "inject",
        "z": "tab-dashboard",
        "name": "Cargar patrones (auto + retry)",
        "props": [],
        "repeat": "15",
        "crontab": "",
        "once": true,
        "onceDelay": "4",
        "x": 170,
        "y": 820,
        "wires": [["http-get-patterns"]]
    },
    {
        "id": "btn-reload-patterns",
        "type": "ui_button",
        "z": "tab-dashboard",
        "name": "Recargar Patrones",
        "group": "group-patterns",
        "order": 4,
        "width": "6",
        "height": "1",
        "passthru": false,
        "label": "Recargar tabla",
        "tooltip": "Recargar lista de patrones desde la API",
        "color": "#ffffff",
        "bgcolor": "#607D8B",
        "icon": "fa-refresh",
        "payload": "reload",
        "payloadType": "str",
        "topic": "",
        "x": 170,
        "y": 860,
        "wires": [["http-get-patterns"]]
    },
    {
        "id": "http-get-patterns",
        "type": "http request",
        "z": "tab-dashboard",
        "name": "GET /api/patterns",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://cep-engine:8291/api/patterns",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "senderr": false,
        "x": 420,
        "y": 820,
        "wires": [["func-render-patterns"]]
    },
    {
        "id": "func-render-patterns",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Preparar tabla patrones",
        "func": "var patterns = msg.payload;\nif (!Array.isArray(patterns)) {\n    node.status({fill:'red', shape:'ring', text:'Error: ' + (msg.statusCode || 'sin respuesta')});\n    return null;\n}\nnode.status({fill:'green', shape:'dot', text: patterns.length + ' patrones'});\nflow.set('patterns', patterns);\nvar rows = patterns.map(function(p) {\n    return {\n        patternId: p.patternId,\n        name: p.name,\n        alertLevel: p.alertLevel,\n        description: p.description || '',\n        estado: p.enabled ? '✅ Activo' : '❌ Desactivado'\n    };\n});\nmsg.payload = rows;\nreturn msg;",
        "outputs": 1,
        "x": 660,
        "y": 820,
        "wires": [["table-patterns"]]
    },
    {
        "id": "table-patterns",
        "type": "ui_table",
        "z": "tab-dashboard",
        "group": "group-patterns",
        "name": "Tabla Patrones",
        "order": 1,
        "width": "24",
        "height": "10",
        "columns": [
            {"field": "patternId",   "title": "ID",           "width": "15%"},
            {"field": "name",        "title": "Nombre",       "width": "20%"},
            {"field": "alertLevel",  "title": "Nivel",        "width": "8%"},
            {"field": "description", "title": "Descripción",  "width": "47%"},
            {"field": "estado",      "title": "Estado",       "width": "10%"}
        ],
        "outputs": 1,
        "cts": true,
        "x": 900,
        "y": 820,
        "wires": [["func-handle-pattern-click"]]
    },
    {
        "id": "func-handle-pattern-click",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Capturar clic en patrón",
        "func": "var row = msg.payload;\nif (!row || !row.patternId) return null;\nflow.set('selectedPatternId', row.patternId);\nmsg.payload = '¿Cambiar estado de: ' + row.name + '?';\nreturn msg;",
        "outputs": 1,
        "x": 660,
        "y": 880,
        "wires": [["text-pattern-selected"]]
    },
    {
        "id": "text-pattern-selected",
        "type": "ui_text",
        "z": "tab-dashboard",
        "group": "group-patterns",
        "order": 2,
        "width": "16",
        "height": "1",
        "name": "Patrón seleccionado",
        "label": "Seleccionado:",
        "format": "{{msg.payload}}",
        "layout": "row-left",
        "x": 900,
        "y": 880,
        "wires": []
    },
    {
        "id": "btn-toggle-pattern",
        "type": "ui_button",
        "z": "tab-dashboard",
        "name": "Toggle Patrón",
        "group": "group-patterns",
        "order": 3,
        "width": "8",
        "height": "1",
        "passthru": false,
        "label": "Habilitar / Deshabilitar",
        "tooltip": "Haz clic en una fila de la tabla y luego en este botón",
        "color": "#ffffff",
        "bgcolor": "#2196F3",
        "icon": "fa-toggle-on",
        "payload": "toggle",
        "payloadType": "str",
        "topic": "",
        "x": 170,
        "y": 940,
        "wires": [["func-build-toggle-request"]]
    },
    {
        "id": "func-build-toggle-request",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Construir petición toggle",
        "func": "var patternId = flow.get('selectedPatternId');\nif (!patternId) {\n    node.warn('Selecciona un patrón de la tabla primero');\n    return null;\n}\nmsg.method = 'PATCH';\nmsg.url = 'http://cep-engine:8291/api/patterns/' + patternId + '/toggle';\nmsg.payload = {};\nreturn msg;",
        "outputs": 1,
        "x": 420,
        "y": 940,
        "wires": [["http-toggle-pattern"]]
    },
    {
        "id": "http-toggle-pattern",
        "type": "http request",
        "z": "tab-dashboard",
        "name": "PATCH toggle",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "senderr": false,
        "x": 660,
        "y": 940,
        "wires": [["func-after-toggle"]]
    },
    {
        "id": "func-after-toggle",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Actualizar tras toggle",
        "func": "var updated = msg.payload;\nif (!updated || !updated.patternId) {\n    node.status({fill:'red', shape:'ring', text:'Error toggle: ' + (msg.statusCode || '?')});\n    return null;\n}\nnode.status({fill:'green', shape:'dot', text: updated.patternId + ' -> ' + (updated.enabled ? 'ON' : 'OFF')});\nvar patterns = flow.get('patterns') || [];\npatterns = patterns.map(function(p) {\n    return p.patternId === updated.patternId ? updated : p;\n});\nflow.set('patterns', patterns);\nvar rows = patterns.map(function(p) {\n    return {\n        patternId: p.patternId,\n        name: p.name,\n        alertLevel: p.alertLevel,\n        description: p.description || '',\n        estado: p.enabled ? '✅ Activo' : '❌ Desactivado'\n    };\n});\nflow.set('selectedPatternId', null);\nmsg.payload = rows;\nreturn msg;",
        "outputs": 1,
        "x": 880,
        "y": 940,
        "wires": [["table-patterns"]]
    }
]
