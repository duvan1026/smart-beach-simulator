    {
        "id": "map-beaches",
        "type": "ui_template",
        "z": "tab-dashboard",
        "group": "group-map",
        "name": "Mapa Leaflet Playas",
        "order": 1,
        "width": "24",
        "height": "10",
        "format": "<!-- Leaflet map with live beach markers -->\n<link rel=\"stylesheet\" href=\"/leaflet.css\"/>\n<script src=\"/leaflet.js\"></script>\n<style>\n  #beach-map-wrap { position: relative; width: 100%; height: 360px; z-index: 0; }\n  #beach-map { position: absolute; top: 0; left: 0; right: 0; bottom: 0; border-radius: 8px; z-index: 0; }\n  .leaflet-pane, .leaflet-top, .leaflet-bottom { z-index: 1 !important; }\n  .leaflet-control { z-index: 2 !important; }\n  .beach-popup { font-size: 13px; line-height: 1.6; }\n  .beach-popup b { font-size: 14px; }\n  .level-OK     { color: #4CAF50; font-weight: bold; }\n  .level-YELLOW { color: #FFC107; font-weight: bold; }\n  .level-ORANGE { color: #FF9800; font-weight: bold; }\n  .level-RED    { color: #f44336; font-weight: bold; }\n</style>\n<div id=\"beach-map-wrap\"><div id=\"beach-map\"></div></div>\n<script>\n(function() {\n  if (window._beachMap) { window._beachMap.remove(); window._beachMap = null; }\n\n  var beaches = [\n    { id: 'victoria',  name: 'Playa de la Victoria', lat: 36.5062, lon: -6.2791 },\n    { id: 'caleta',    name: 'Playa de la Caleta',    lat: 36.5313, lon: -6.3059 },\n    { id: 'cortadura', name: 'Playa de Cortadura',    lat: 36.4878, lon: -6.2676 }\n  ];\n\n  var alertColors = { OK: '#4CAF50', YELLOW: '#FFC107', ORANGE: '#FF9800', RED: '#f44336' };\n\n  var map = L.map('beach-map', { preferCanvas: true }).setView([36.510, -6.285], 13);\n  window._beachMap = map;\n\n  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\n    attribution: '© OpenStreetMap contributors',\n    maxZoom: 18\n  }).addTo(map);\n\n  // Force Leaflet to recalculate its container size after Angular finishes rendering\n  setTimeout(function() { map.invalidateSize(); }, 300);\n\n  var markers = {};\n  var sensorData = {};\n\n  function makeIcon(color) {\n    return L.divIcon({\n      className: '',\n      html: '<div style=\"width:20px;height:20px;border-radius:50%;background:' + color + ';border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,0.4);\"></div>',\n      iconSize: [20, 20],\n      iconAnchor: [10, 10]\n    });\n  }\n\n  function popupContent(beach, data, alertLevel) {\n    var lvl = alertLevel || 'OK';\n    var cls = 'level-' + lvl;\n    var html = '<div class=\"beach-popup\">';\n    html += '<b>' + beach.name + '</b><br>';\n    html += 'Estado: <span class=\"' + cls + '\">' + lvl + '</span><br>';\n    if (data) {\n      html += '🌬 Viento: <b>' + (data.windSpeed||'-') + ' km/h</b><br>';\n      html += '🌡 Temp: <b>' + (data.temperature||'-') + ' °C</b><br>';\n      html += '📊 Presión: <b>' + (data.pressure||'-') + ' hPa</b><br>';\n      html += '🌊 Nivel mar: <b>' + (data.seaLevel||'-') + ' m</b><br>';\n      html += '👥 Ocupación: <b>' + (data.occupancy||'-') + '%</b>';\n    } else {\n      html += '<i>Esperando datos...</i>';\n    }\n    html += '</div>';\n    return html;\n  }\n\n  beaches.forEach(function(b) {\n    var marker = L.marker([b.lat, b.lon], { icon: makeIcon('#4CAF50') })\n      .addTo(map)\n      .bindPopup(popupContent(b, null, 'OK'), { maxWidth: 220 });\n    markers[b.id] = { marker: marker, alertLevel: 'OK', beach: b };\n  });\n\n  scope.$watch('msg', function(msg) {\n    if (!msg || !msg.payload) return;\n    var d = msg.payload;\n\n    if (d.type === 'readings' && d.data && d.data.beachId) {\n      var bid = d.data.beachId;\n      sensorData[bid] = d.data;\n      if (markers[bid]) {\n        var m = markers[bid];\n        m.marker.setPopupContent(popupContent(m.beach, d.data, m.alertLevel));\n      }\n    }\n\n    if (d.type === 'alert' && d.data && d.data.beachId) {\n      var bid = d.data.beachId;\n      var lvl = d.data.alertLevel || 'OK';\n      if (markers[bid]) {\n        var m = markers[bid];\n        m.alertLevel = lvl;\n        m.marker.setIcon(makeIcon(alertColors[lvl] || '#4CAF50'));\n        m.marker.setPopupContent(popupContent(m.beach, sensorData[bid] || null, lvl));\n      }\n    }\n  });\n})();\n</script>",
        "storeOutMessages": true,
        "fwd": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "x": 600,
        "y": 560,
        "wires": [[]]
    },

    {
        "id": "inject-ws-start",
        "type": "inject",
        "z": "tab-dashboard",
        "name": "Start WS",
        "props": [],
        "repeat": "10",
        "crontab": "",
        "once": true,
        "onceDelay": "3",
        "x": 140,
        "y": 620,
        "wires": [["ws-in-cep"]]
    },
    {
        "id": "ws-in-cep",
        "type": "function",
        "z": "tab-dashboard",
        "name": "CEP WebSocket Client",
        "func": "var WS = global.get('ws');\nif (!WS) { node.error('ws not in global context'); return; }\n\nvar client = flow.get('wsClient');\nif (client && client.readyState === 1) return;\n\nif (client && client.readyState !== 3) {\n    try { client.terminate(); } catch(e) {}\n}\n\nvar ws = new WS('ws://cep-engine:8291/ws/sensors');\nflow.set('wsClient', ws);\n\nws.on('open', function() {\n    node.status({fill:'green', shape:'dot', text:'connected'});\n});\n\nws.on('message', function(data) {\n    var parsed;\n    try { parsed = JSON.parse(data.toString()); } catch(e) { return; }\n    node.send({payload: parsed});\n});\n\nws.on('close', function() {\n    node.status({fill:'red', shape:'ring', text:'disconnected'});\n    flow.set('wsClient', null);\n});\n\nws.on('error', function(err) {\n    node.status({fill:'red', shape:'ring', text:err.message});\n    flow.set('wsClient', null);\n});",
        "outputs": 1,
        "x": 340,
        "y": 620,
        "wires": [["func-route-ws"]]
    },
    {
        "id": "func-route-ws",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Route by Type",
        "func": "var data;\ntry {\n    data = (typeof msg.payload === 'string') ? JSON.parse(msg.payload) : msg.payload;\n} catch(e) { return null; }\n\nif (data.type === 'alert') {\n    flow.set('lastAlertTime', Date.now());\n    return [null, {payload: data.data}, {payload: msg.payload}];\n}\n\nif (data.type === 'readings') {\n    var lastAlert = flow.get('lastAlertTime') || 0;\n    var elapsed = Date.now() - lastAlert;\n    if (lastAlert > 0 && elapsed > 10000) {\n        flow.set('lastAlertTime', 0);\n        return [{payload: data.data}, {payload: {alertLevel: 'OK'}}, {payload: msg.payload}];\n    }\n    return [{payload: data.data}, null, {payload: msg.payload}];\n}\nreturn null;",
        "outputs": 3,
        "x": 560,
        "y": 620,
        "wires": [
            ["func-split-sensors"],
            ["func-format-alert", "func-accumulate-events"],
            ["map-beaches"]
        ]
    },
    {
        "id": "func-split-sensors",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Split to Charts",
        "func": "var d = msg.payload;\nif (!d || !d.beachId) return null;\nvar wind     = {topic: d.beachId, payload: d.windSpeed};\nvar pressure = {topic: d.beachId, payload: d.pressure};\nvar temp     = {topic: d.beachId, payload: d.temperature};\nvar sea      = {topic: d.beachId, payload: d.seaLevel};\nvar occ      = {topic: d.beachId, payload: d.occupancy};\nreturn [wind, pressure, temp, sea, occ];",
        "outputs": 5,
        "x": 800,
        "y": 560,
        "wires": [["chart-wind"], ["chart-pressure"], ["chart-temp"], ["chart-sealevel"], ["chart-occupancy"]]
    },
    {
        "id": "func-format-alert",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Format Alert",
        "func": "var d = msg.payload;\nif (!d) return null;\nvar level = d.alertLevel || 'UNKNOWN';\nif (level === 'OK') {\n    msg.payload = '<font color=\"#4CAF50\" size=\"4\"><b>[OK]</b></font> All clear - No active alerts';\n    return msg;\n}\nvar color = '#4CAF50';\nif (level === 'YELLOW') color = '#FFEB3B';\nif (level === 'ORANGE') color = '#FF9800';\nif (level === 'RED') color = '#f44336';\nmsg.payload = '<font color=\"' + color + '\" size=\"4\"><b>[' + level + ']</b></font> ' + (d.message || d.patternName || 'Alert') + ' - ' + (d.beachId || '') + ' @ ' + (d.timestamp || '');\nreturn msg;",
        "outputs": 1,
        "x": 800,
        "y": 640,
        "wires": [["alert-display"]]
    },
    {
        "id": "func-accumulate-events",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Accumulate Events",
        "func": "var events = flow.get('eventsLog') || [];\nvar d = msg.payload;\nif (!d) return null;\nevents.unshift({\n    alertLevel: d.alertLevel || '',\n    patternName: d.patternName || '',\n    beachId: d.beachId || '',\n    message: d.message || '',\n    timestamp: d.timestamp || ''\n});\nif (events.length > 50) events = events.slice(0, 50);\nflow.set('eventsLog', events);\nmsg.payload = events;\nreturn msg;",
        "outputs": 1,
        "x": 800,
        "y": 700,
        "wires": [["events-table"]]
    },
